# =============================================================
# Copy to .env and fill in. NEVER commit .env to git.
# =============================================================

# --- Pronote / Monlycée credentials (required, both modes) ---
MONLYCEE_USER=your.username
MONLYCEE_PASS=your_password
PRONOTE_URL=https://XXXXXXXX.index-education.net/pronote/eleve.html

# --- HTTP mode only (server_http.py / Docker) ---

# Strong random token. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# Minimum 24 chars; 48+ recommended.
MCP_AUTH_TOKEN=

# Bind address (default 127.0.0.1 for direct run, 0.0.0.0 inside Docker).
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=8765

# --- Docker / Caddy only ---

# Domain pointing to your VPS (A/AAAA record). Caddy will auto-provision
# a Let's Encrypt certificate for this domain.
DOMAIN=pronote-mcp.example.com
